---
import ContactButton from "../ContactButton.astro";
import Container from "../Container.astro";
---

<section>
  <!--Sección de color azul -->
  <section id="contacto" class="bg-linear-to-b from-violet-200 to-white py-16">
    <Container class="text-violet-950 max-w-6xl">

      <div class="bg-violet-200 rounded-4xl border border-violet-300 p-16 text-center flex flex-col items-center shadow-2xl gap-2">

        <h2 class="text-5xl font-bold font-serif leading-normal max-w-3xl">
          ¡Hagamos de tu evento algo inolvidable!
        </h2>
  
        <p class="text-2xl mb-4">
          Cuentanos tus ideas y nosotros nos encargamos del sabor y la
          experiencia.
        </p>

        <ContactButton title="Hablemos por WhatsApp" class="text-2xl px-6"/>

      </div>
    </Container>
  </section>
</section>